# Use nix-direnv for cached nix develop evaluation (much faster re-entry).
# Falls back to plain `use flake` if nix-direnv is not available.
if has nix_direnv_version 2>/dev/null; then
  nix_direnv_version 3.0.6  # minimum nix-direnv version
  use flake
elif has use_flake 2>/dev/null; then
  use flake
elif [[ -f flake.nix ]]; then
  use flake
else
  echo "No flake.nix found, skipping nix flake environment"
fi
